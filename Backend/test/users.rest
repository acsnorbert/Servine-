@host = http://localhost
@port = 3000
@url = {{host}}:{{port}}


@adminToken = {{login.response.body.token}}
@userToken = {{login.response.body.token}}

# @name login
POST {{url}}/api/auth/login
Content-Type: application/json

{
  "email": "teszt@example.com",
  "password": "jelszo123"
}

### Saját profil lekérése (auth kell)
GET {{url}}/api/users/profile
Authorization: Bearer {{userToken}}

### Összes felhasználó listázása (csak admin)
GET {{url}}/api/users
Authorization: Bearer {{adminToken}}

### Egy konkrét felhasználó adatainak lekérése (admin vagy saját maga)
GET {{url}}/api/users/144c8488-9550-4873-bc0a-b30867f27ea8
Authorization: Bearer {{adminToken}}

### Saját adatok módosítása (pl. név vagy email váltás)
PATCH {{url}}/api/users/profile
Content-Type: application/json
Authorization: Bearer {{userToken}}

{
  "name": "Teszt User Új Név",
  "email": "email@example.com"
}
### Felhasználó törlése (csak admin!)
DELETE {{url}}/api/users/b9c62901-813b-4166-acb6-fc6d3bbbe40e
Authorization: Bearer {{adminToken}}